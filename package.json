{
  "type": "module",
  "name": "free-actions-core",
  "version": "0.0.1",
  "description": "Expose any remote MCP server as ChatGPT-compatible OpenAPI Actions. A vendor-neutral \"mcp-mimic\" bridge: a generic GET /tools + POST /call surface that mirrors MCP tools/list + tools/call so non-MCP agents (Custom GPTs, any OpenAPI-Action consumer) can call MCP tools with zero per-user auth.",
  "license": "Apache-2.0",
  "author": "chisakiShinichirouToshiyuki",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && tsc -p tsconfig.json",
    "prepare": "bun run build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "format": "biome format --write src/",
    "check": "biome check src/",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "type-coverage": "type-coverage --strict --at-least 95 --ignore-files \"src/**/*.test.ts\" --ignore-files \"src/**/*.test-d.ts\"",
    "attw": "attw --pack . --ignore-rules cjs-resolves-to-esm",
    "ci": "bun run check && bun run typecheck && bun run type-coverage && bun run test:coverage && bun run build && bun run attw",
    "dev": "tsc -w -p tsconfig.json"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "openapi",
    "chatgpt",
    "actions",
    "gpts",
    "bridge"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chisakiShinichirouToshiyuki/free-actions-core.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25"
  },
  "peerDependencies": {
    "free-mcp-core": "^0.1.0-rc.7"
  },
  "peerDependenciesMeta": {
    "free-mcp-core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@biomejs/biome": "^2",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^24",
    "@vitest/coverage-v8": "^3",
    "fast-check": "^4.8.0",
    "type-coverage": "^2.29.7",
    "typescript": "^5.9.3",
    "vitest": "^3"
  },
  "packageManager": "bun@1.3.10"
}
